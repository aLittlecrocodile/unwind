# Floppy backend 环境变量模板。复制为 .env 后填入真实值（.env 已被 gitignore）。
# 前缀统一 FLOPPY_。下面只列实时语音对话链路相关项，其余见 config.py。

# ── 对话 LLM（OpenAI 兼容流式 /chat/completions）────────────────────
# 优先用 DIALOG_LLM_*，留空则回退到 QUERY_PLANNER_*
FLOPPY_DIALOG_LLM_API_KEY=
FLOPPY_DIALOG_LLM_BASE_URL=
FLOPPY_DIALOG_LLM_MODEL=
# 回退根凭证（query planner 复用）
FLOPPY_QUERY_PLANNER_API_KEY=
FLOPPY_QUERY_PLANNER_BASE_URL=https://api.openai.com/v1
FLOPPY_QUERY_PLANNER_MODEL=DeepSeek-V4-Flash

# ── Agent Runtime：local 或 Hermes Agent API Server ───────────────────
# local：使用后端内置 LangGraph agent；hermes：Hermes 决策，Floppy 执行 workflow
FLOPPY_AGENT_RUNTIME=local
FLOPPY_HERMES_BASE_URL=http://127.0.0.1:8642
FLOPPY_HERMES_API_KEY=
FLOPPY_HERMES_MODEL=hermes-agent
# responses for a native Hermes API; chat for OpenAI-compatible OneAPI gateways
FLOPPY_HERMES_API_STYLE=responses
FLOPPY_HERMES_TIMEOUT_SEC=30
FLOPPY_HERMES_STORE_CONVERSATION=true
FLOPPY_HERMES_FALLBACK_TO_LOCAL=true

# ── 火山引擎流式 ASR（语音控制台的应用 App Key / Access Key，非账号级 AK/SK）──
FLOPPY_VOLC_ASR_APP_KEY=
FLOPPY_VOLC_ASR_ACCESS_KEY=
FLOPPY_VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration
FLOPPY_VOLC_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
FLOPPY_VOLC_ASR_SAMPLE_RATE=16000

# ── MiniMax 流式 TTS（中文站 key；base_url 用 minimaxi.com，.io 会 401）──
FLOPPY_MINIMAX_API_KEY=
FLOPPY_MINIMAX_BASE_URL=https://api.minimaxi.com
FLOPPY_MINIMAX_WS_URL=wss://api.minimaxi.com/ws/v1/t2a_v2
FLOPPY_MINIMAX_STREAM_MODEL=speech-2.6-turbo

# ── /voice/ws 鉴权（PoC shared-secret；留空则端点无鉴权，仅限内网）──
FLOPPY_VOICE_WS_TOKEN=
